# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/vel-ai

# ── Redis (Upstash) ──────────────────────────
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Auth ─────────────────────────────────────
JWT_SECRET=your-32-char-min-secret-key-here
ENCRYPTION_KEY=your-32-char-min-encryption-key

# ── OpenRouter ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_API_KEY_CLAUDE=sk-or-v1-your-claude-key
OPENROUTER_API_KEY_GEMINI=sk-or-v1-your-gemini-key

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_BYOK_MONTHLY=price_pro_byok
STRIPE_PRICE_TEAMS_MONTHLY=price_teams

# ── Storage (Cloudflare R2) ──────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=vel-ai-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
R2_REQUEST_TIMEOUT=30000

# ── Observability ────────────────────────────
SENTRY_DSN=https://your-dsn@o123.ingest.sentry.io/123
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── AI Research ──────────────────────────────
TAVILY_API_KEY=tvly-your-key
PERPLEXITY_API_KEY=pplx-your-key
OPENAI_API_KEY=sk-your-openai-key

# ── Server ───────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
