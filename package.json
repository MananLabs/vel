{
  "name": "vel-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@vel-ai/web",
    "dev:backend": "turbo run dev --filter=@vel-ai/api",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "npm run db:generate --workspace=@vel-ai/api",
    "db:migrate": "npm run db:migrate --workspace=@vel-ai/api",
    "db:push": "npm run db:migrate --workspace=@vel-ai/api",
    "db:studio": "npm run db:studio --workspace=@vel-ai/api",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1057.0",
    "@aws-sdk/lib-dynamodb": "^3.1057.0"
  }
}
