# ═══════════════════════════════════════════════════════════
# VEL AI — Environment Variables
# Copy to .env (api) and .env.local (web)
# ═══════════════════════════════════════════════════════════

# ─── Backend (apps/api/.env) ──────────────────────────────

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/velai?sslmode=require

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xyz.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Cloudflare R2
R2_ACCOUNT_ID=abc123
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=yyy
R2_BUCKET_NAME=vel-ai-storage
R2_PUBLIC_URL=https://pub.r2.dev/vel-ai-storage

# Auth (Clerk)
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# AI (OpenRouter + Direct)
OPENROUTER_API_KEY=sk-or-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Web Search (choose one)
TAVILY_API_KEY=tvly-xxx
# PERPLEXITY_API_KEY=pplx-xxx

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_BYOK_MONTHLY=price_xxx
STRIPE_PRICE_TEAMS_MONTHLY=price_xxx
STRIPE_PRICE_CREDITS_500=price_xxx
STRIPE_PRICE_CREDITS_2000=price_xxx
STRIPE_PRICE_CREDITS_10000=price_xxx

# Encryption
ENCRYPTION_KEY=64-char-hex-string-for-aes-256-gcm

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Observability
SENTRY_DSN=https://xxx@sentry.io/yyy


# ─── Frontend (apps/web/.env.local) ──────────────────────

# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
# CLERK_SECRET_KEY=sk_live_xxx
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:3001
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
